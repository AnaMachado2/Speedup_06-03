import hashlib
import time
import threading

def md5_string(texto):
    return hashlib.md5(texto.encode('utf-8')).hexdigest()

senha_encontrada = False
lock = threading.Lock()

def buscahash_intervalo(hashbuscado, inicio, fim, nome_thread):

    global senha_encontrada

    for numero in range(inicio, fim):

        if senha_encontrada:
            return

        combinacao = f"{numero:09d}"
        hash_valor = md5_string(combinacao)

        if hashbuscado == hash_valor:
            with lock:
                senha_encontrada = True
                print(f"\n{nome_thread} encontrou a senha: {combinacao}")
            return


def buscahash9_threads(hashbuscado, num_threads):

    global senha_encontrada
    senha_encontrada = False

    total = 1000000000
    intervalo = total // num_threads

    threads = []

    for i in range(num_threads):

        inicio = i * intervalo

        if i == num_threads - 1:
            fim = total
        else:
            fim = (i + 1) * intervalo

        t = threading.Thread(
            target=buscahash_intervalo,
            args=(hashbuscado, inicio, fim, f"Thread {i+1}")
        )

        threads.append(t)

    inicio_tempo = time.time()

    # inicia todas as threads
    for t in threads:
        t.start()

    # aguarda terminar
    for t in threads:
        t.join()

    fim_tempo = time.time()

    print(f"\nTempo de execução: {fim_tempo - inicio_tempo:.4f} segundos")


